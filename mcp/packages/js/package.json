{
  "name": "@trainheroic-unofficial/js",
  "version": "0.1.0",
  "description": "Unofficial TypeScript SDK for the (reverse-engineered) TrainHeroic coaching API.",
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" }
  },
  "publishConfig": {
    "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
