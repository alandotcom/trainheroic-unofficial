{
  "name": "@trainheroic-unofficial/js",
  "version": "0.1.0",
  "description": "Unofficial TypeScript SDK for the TrainHeroic coaching API.",
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" },
    "./node": { "types": "./src/node.ts", "import": "./src/node.ts" }
  },
  "publishConfig": {
    "exports": {
      ".": { "types": "./dist/index.d.mts", "import": "./dist/index.mjs" },
      "./node": { "types": "./dist/node.d.mts", "import": "./dist/node.mjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@trainheroic-unofficial/dto": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
