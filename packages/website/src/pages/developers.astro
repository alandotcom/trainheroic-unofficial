---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../lib/paths.ts";
---

<Layout
  title="Developers"
  description="Claude Code skill, TypeScript SDK, and MCP reference for TrainHeroic integrations."
>
  <Header />
  <main id="main">
    <div class="shell narrow">
      <header class="doc__intro">
        <h1>Developers</h1>
        <p class="lead">
          Documentation for Claude Code, scripts, and custom apps. To connect Claude.ai in the
          browser, use the <a href={withBase("")}>connector setup</a> on the home page.
        </p>
      </header>

      <section class="doc">
        <ul class="doc-list">
          <li>
            <a href={withBase("skill")}>Claude Code skill</a>: run <code>npx skills add</code>, then the agent
            calls <code>trainheroic</code>.
          </li>
          <li>
            <a href={withBase("sdk")}>TypeScript SDK</a>: package <code>@trainheroic-unofficial/js</code> for
            scripts and workers.
          </li>
          <li>
            <a href={withBase("mcp")}>MCP reference</a>: Cursor, Claude Desktop, local stdio servers, and the
            tool catalog.
          </li>
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
