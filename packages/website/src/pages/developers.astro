---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Developers"
  description="Claude Code skill, TypeScript SDK, and MCP reference for building TrainHeroic integrations."
>
  <Header />
  <main id="main">
    <div class="shell narrow">
      <header class="doc__intro">
        <h1>Developers</h1>
        <p class="lead">
          For Claude Code, scripts, and custom integrations. Using Claude.ai in the browser?
          <a href="/">Connector setup</a>.
        </p>
      </header>

      <section class="doc">
        <ul class="doc-list">
          <li>
            <strong><a href="/skill">Claude Code skill</a></strong> — install with
            <code>npx skills add</code>, run <code>trainheroic</code> from the agent
          </li>
          <li>
            <strong><a href="/sdk">TypeScript SDK</a></strong> —
            <code>@trainheroic-unofficial/js</code> for scripts and workers
          </li>
          <li>
            <strong><a href="/mcp">MCP reference</a></strong> — Cursor, Claude Desktop, local
            servers, tool list
          </li>
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
