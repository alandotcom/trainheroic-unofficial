---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Developers"
  description="Claude Code skill, TypeScript SDK, and MCP reference for building TrainHeroic integrations."
>
  <Header />
  <main id="main">
    <div class="shell">
      <header class="doc__intro narrow">
        <h1>Developers</h1>
        <p class="lead">
          Integrate TrainHeroic in code or with a coding agent. For Claude.ai in the browser, use
          the <a href="/">hosted connector setup</a> instead.
        </p>
      </header>

      <section class="doc narrow">
        <ul class="list-plain">
          <li>
            <strong><a href="/skill">Claude Code skill & CLI</a></strong> — recommended for Claude
            Code and agents that run shell commands. Install with
            <code>npx skills add</code>, drive the API through <code>trainheroic</code>.
          </li>
          <li>
            <strong><a href="/sdk">TypeScript SDK</a></strong> — <code>@trainheroic-unofficial/js</code>
            for scripts, workers, and custom apps. Typed helpers for workouts, roster, athlete reads,
            and messaging.
          </li>
          <li>
            <strong><a href="/mcp">MCP reference</a></strong> — Cursor, Claude Desktop, local stdio
            servers, and the full tool list. Most users should use the <a href="/">Claude.ai
              connector</a>.
          </li>
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
