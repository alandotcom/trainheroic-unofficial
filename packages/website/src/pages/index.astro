---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CopyLine from "../components/CopyLine.astro";
import Snippet from "../components/Snippet.astro";
import { CLAUDE_AI_CONNECTOR_URL, MCP_URL } from "../data/tools";
---

<Layout
  title="Connect to Claude"
  description="Connect your TrainHeroic account to Claude.ai in three steps — ask about your roster, programming, and training."
>
  <Header />
  <main id="main">
    <div class="shell">
      <header class="doc__intro narrow">
        <h1>Connect TrainHeroic to Claude</h1>
        <p class="lead">
          Ask Claude about your athletes, workouts, and training history — using the TrainHeroic
          account you already have. No API key. Sign in once.
        </p>
      </header>

      <section class="doc narrow" id="setup">
        <h2>Set up in Claude.ai</h2>
        <ol class="steps">
          <li>
            <p>
              Open <a href={CLAUDE_AI_CONNECTOR_URL}>Settings → Connectors → Add custom connector</a
              > in Claude.ai.
            </p>
          </li>
          <li>
            <p>Paste this URL when asked for the connector address:</p>
            <CopyLine text={MCP_URL} label="Connector URL" />
          </li>
          <li>
            <p>
              Sign in with your <strong>TrainHeroic email and password</strong> when Claude prompts
              you. A coach account gets coaching and your own athlete tools; an athlete account
              gets athlete tools.
            </p>
          </li>
        </ol>
      </section>

      <section class="doc narrow">
        <h2>Try it</h2>
        <p>Start a chat in Claude and ask in plain language:</p>
        <Snippet
          label="Example questions"
          code={`List my athletes
What's on the program for Tuesday?
Show my squat PRs this year
Draft a back squat workout for next Monday — don't publish yet`}
        />
      </section>

      <section class="doc narrow">
        <h2>What you can ask</h2>
        <ul class="list-plain">
          <li>
            <strong>Coaches</strong> — roster, program workouts, teams, athlete analytics, messages
          </li>
          <li>
            <strong>Athletes</strong> — training history, PRs, working maxes, what's programmed today
          </li>
          <li>
            <strong>Safety</strong> — Claude asks before publishing workouts or sending messages
          </li>
        </ul>
      </section>

      <section class="doc narrow">
        <p class="disclaimer">
          <strong>Unofficial</strong> — not affiliated with TrainHeroic. Your login is handled by
          OAuth on the hosted connector; we do not store your password in plaintext on the server.
        </p>
        <p>
          Building with Claude Code or TypeScript? See the <a href="/developers">developer docs</a>.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
