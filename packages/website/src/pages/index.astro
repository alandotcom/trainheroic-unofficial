---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import { pageHref } from "../lib/paths.ts";
import { CLAUDE_AI_CONNECTOR_URL, MCP_URL } from "../data/tools";
---

<Layout
  title="Connect to Claude"
  description="Connect your TrainHeroic account to Claude.ai. Ask about your roster, programming, and training."
>
  <Header />
  <main id="main">
    <div class="shell narrow">
      <header class="doc__intro">
        <h1>Connect TrainHeroic to Claude</h1>
        <p class="lead">
          Claude can read your TrainHeroic data when you sign in with the same email and password you
          use in the app.
        </p>
      </header>

      <section class="doc" id="setup">
        <h2>Set up in Claude.ai</h2>
        <ol class="doc-steps">
          <li>
            <p>
              Open
              <a href={CLAUDE_AI_CONNECTOR_URL}>Settings → Connectors → Add custom connector</a>.
            </p>
          </li>
          <li>
            <p>Paste the connector URL:</p>
            <Snippet code={MCP_URL} lang="text" />
          </li>
          <li>
            <p>
              Sign in with your <strong>TrainHeroic email and password</strong> when Claude asks.
            </p>
          </li>
        </ol>
      </section>

      <section class="doc">
        <h2>Try it</h2>
        <p>Start a chat and ask a question like one of these:</p>
        <Snippet
          lang="text"
          code={`List my athletes
What's on the program for Tuesday?
Show my squat PRs this year
Draft a back squat workout for next Monday (keep it unpublished)`}
        />
      </section>

      <section class="doc">
        <h2>What you can ask</h2>
        <ul class="doc-list">
          <li>Coaches can query roster, workouts, teams, analytics, and messages.</li>
          <li>Athletes can look up history, PRs, working maxes, and today's program.</li>
          <li>Claude confirms before publishing workouts or sending messages.</li>
        </ul>
      </section>

      <section class="doc">
        <p class="disclaimer">
          <strong>Unofficial project.</strong> TrainHeroic is a separate company. OAuth stores your
          login on the hosted connector server.
        </p>
        <p>Integrating in code? See <a href={pageHref("developers", Astro.url.pathname)}>developer docs</a>.</p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
