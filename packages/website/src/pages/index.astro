---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import { MCP_URL, NPM_JS, NPM_COACH_MCP } from "../data/tools";
---

<Layout
  title="TrainHeroic MCP & SDK"
  description="Connect Claude and other AI assistants to TrainHeroic through MCP tools, or build your own integrations with the TypeScript SDK."
>
  <Header />
  <main>
    <div class="shell">
      <header class="doc__intro">
        <h1>TrainHeroic for assistants and code</h1>
        <p class="lead">
          Unofficial toolkit for the TrainHeroic API. Wire Claude to your roster, or script the
          same endpoints yourself.
        </p>
        <ul class="doc__links">
          <li><a href="/mcp">MCP server</a></li>
          <li><a href="/sdk">TypeScript SDK</a></li>
          <li><a href={MCP_URL}>Hosted endpoint ↗</a></li>
        </ul>
      </header>

      <section class="doc">
        <Snippet
          code={`# Hosted MCP (OAuth)
claude mcp add trainheroic --transport http \\
  ${MCP_URL}

# Local coach (stdio)
claude mcp add trainheroic \\
  -e TRAINHEROIC_EMAIL=you@example.com \\
  -e TRAINHEROIC_PASSWORD=•••••••• \\
  -- npx -y ${NPM_COACH_MCP}`}
        />
        <span class="url-line">{MCP_URL}</span>
      </section>

      <section class="doc narrow">
        <h2>What you get</h2>
        <ul class="list-plain">
          <li><strong>Coach</strong> — program workouts, manage athletes and teams, analytics, messaging</li>
          <li><strong>Athlete</strong> — training history, PRs, working maxes, session logging</li>
          <li><strong>SDK</strong> — <code>{NPM_JS}</code> for your own scripts and workers</li>
        </ul>
      </section>

      <section class="doc narrow">
        <p class="faint">
          Unofficial, not affiliated with TrainHeroic. Hosted OAuth keeps credentials server-side;
          local configs store email and password in plaintext.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
