---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import { CLAUDE_AI_CONNECTOR_URL, MCP_URL } from "../data/tools";
---

<Layout
  title="Connect to Claude"
  description="Connect your TrainHeroic account to Claude.ai in three steps — ask about your roster, programming, and training."
>
  <Header />
  <main id="main">
    <div class="shell narrow">
      <header class="doc__intro">
        <h1>Connect TrainHeroic to Claude</h1>
        <p class="lead">
          Ask Claude about your athletes, workouts, and training history. Sign in with your
          TrainHeroic account — no API key.
        </p>
      </header>

      <section class="doc" id="setup">
        <h2>Set up in Claude.ai</h2>
        <ol class="doc-steps">
          <li>
            Open
            <a href={CLAUDE_AI_CONNECTOR_URL}>Settings → Connectors → Add custom connector</a>.
          </li>
          <li>
            Paste this URL:
            <Snippet code={MCP_URL} lang="text" />
          </li>
          <li>
            Sign in with your <strong>TrainHeroic email and password</strong> when prompted.
          </li>
        </ol>
      </section>

      <section class="doc">
        <h2>Try it</h2>
        <p>Ask in plain language:</p>
        <Snippet
          lang="text"
          code={`List my athletes
What's on the program for Tuesday?
Show my squat PRs this year
Draft a back squat workout for next Monday — don't publish yet`}
        />
      </section>

      <section class="doc">
        <h2>What you can ask</h2>
        <ul class="doc-list">
          <li><strong>Coaches</strong> — roster, workouts, teams, analytics, messages</li>
          <li><strong>Athletes</strong> — history, PRs, working maxes, today's program</li>
          <li><strong>Safety</strong> — Claude asks before publishing or sending messages</li>
        </ul>
      </section>

      <section class="doc">
        <p class="disclaimer">
          <strong>Unofficial</strong> — not affiliated with TrainHeroic. OAuth keeps your login
          server-side.
        </p>
        <p>Building with code? <a href="/developers">Developer docs</a>.</p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
