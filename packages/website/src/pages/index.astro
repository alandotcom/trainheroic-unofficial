---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { MCP_URL } from "../data/tools";
---

<Layout
  title="TrainHeroic MCP & SDK"
  description="Connect Claude and other AI assistants to TrainHeroic through MCP tools, or build your own integrations with the TypeScript SDK."
>
  <Header />
  <main id="main">
    <div class="shell">
      <header class="doc__intro">
        <h1>TrainHeroic for assistants and code</h1>
        <p class="lead">
          Unofficial toolkit for the TrainHeroic API. Connect an AI assistant to your roster, or
          script the same endpoints in TypeScript.
        </p>
        <ul class="doc__links">
          <li><a href="/mcp">Set up MCP</a></li>
          <li><a href="/sdk">Use the SDK</a></li>
          <li>
            <a href={MCP_URL} aria-label="Hosted MCP endpoint (opens in new tab)" target="_blank" rel="noopener noreferrer"
              >Hosted endpoint<span aria-hidden="true"> ↗</span></a
            >
          </li>
        </ul>
      </header>

      <section class="doc narrow">
        <h2>Pick a path</h2>
        <ul class="list-plain">
          <li>
            <strong>Hosted MCP</strong> — OAuth at <code>{MCP_URL}</code>. Recommended for Claude.ai,
            Cursor, and Claude Desktop. Credentials stay on the server.
          </li>
          <li>
            <strong>Local MCP</strong> — stdio on your machine via <code>npx</code>. One
            TrainHeroic account per process; email and password in your config.
          </li>
          <li>
            <strong>TypeScript SDK</strong> — <code>@trainheroic-unofficial/js</code> for scripts,
            workers, and custom integrations without MCP.
          </li>
        </ul>
        <p>
          <a href="/mcp#tools">Browse the MCP tool list</a> or jump to <a href="/mcp#setup">setup
            instructions</a>.
        </p>
      </section>

      <section class="doc narrow">
        <h2>What you get</h2>
        <ul class="list-plain">
          <li>
            <strong>Coach</strong> — program workouts, manage athletes and teams, analytics,
            messaging
          </li>
          <li>
            <strong>Athlete</strong> — training history, PRs, working maxes, session logging
          </li>
          <li>
            <strong>Confirm gates</strong> — destructive writes ask before they run
          </li>
        </ul>
      </section>

      <section class="doc narrow">
        <p class="disclaimer">
          <strong>Unofficial</strong> — not affiliated with TrainHeroic. On the hosted server,
          OAuth keeps your credentials server-side. Local stdio configs store
          <code>TRAINHEROIC_EMAIL</code> and <code>TRAINHEROIC_PASSWORD</code> in plaintext on
          your machine.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
