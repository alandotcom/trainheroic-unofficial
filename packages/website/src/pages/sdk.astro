---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import { NPM_DTO, NPM_JS } from "../data/tools";
---

<Layout
  title="TypeScript SDK"
  description="Runtime-agnostic TypeScript SDK for TrainHeroic — exercises, workouts, athlete training, analytics, and messaging."
>
  <Header />
  <main>
    <div class="shell">
      <header class="doc__intro narrow">
        <h1>SDK</h1>
        <p class="lead">
          <code>{NPM_JS}</code> — auth, exercises, workouts, roster helpers, athlete reads,
          analytics, messaging. Runs on Node, workerd, and browsers. Types in <code>{NPM_DTO}</code
          >.
        </p>
      </header>

      <section class="doc">
        <Snippet code={`npm install ${NPM_JS}`} />
      </section>

      <section class="doc narrow">
        <h2>Coach workflow</h2>
        <p>List your roster, resolve an exercise by name, program a draft session.</p>
        <Snippet
          code={`import {
  TrainHeroicClient,
  ExerciseLibrary,
  buildSession,
  fetchCoachRoster,
} from "${NPM_JS}";
import { JsonFileLibraryCache } from "${NPM_JS}/node";

const client = new TrainHeroicClient(email, password);
const library = new ExerciseLibrary(client, new JsonFileLibraryCache());

for (const athlete of await fetchCoachRoster(client)) {
  console.log(athlete.name, athlete.id);
}

const { match } = await library.resolve("Back Squat");
if (!match) throw new Error("Resolve to one exercise first");

const { pwId } = await buildSession(client, {
  programId: 12345,
  date: [2026, 6, 22],
  blocks: [{
    title: "Strength",
    exercises: [{ id: match.id, sets: 5, reps: 5, weight: 225, rpe: 8 }],
  }],
  publish: false,
});`}
        />
      </section>

      <section class="doc narrow">
        <h2>Athlete reads</h2>
        <p>Profile, PRs, and history for the signed-in account.</p>
        <Snippet
          code={`import {
  TrainHeroicClient,
  resolveAthleteUserId,
  fetchAthleteProfileSummary,
  searchExerciseHistory,
  fetchExerciseHistoryDetail,
  fetchPersonalRecords,
} from "${NPM_JS}";

const client = new TrainHeroicClient(email, password);
const userId = await resolveAthleteUserId(client);

const profile = await fetchAthleteProfileSummary(client, userId);
console.log(profile.volume_sum);

const [squat] = await searchExerciseHistory(client, "back squat", 1);
if (squat) {
  const id = Number(squat.id);
  console.log(await fetchExerciseHistoryDetail(client, id, userId));
  console.log(await fetchPersonalRecords(client, id));
}`}
        />
      </section>

      <section class="doc narrow">
        <h2>Analytics & messaging</h2>
        <Snippet
          code={`import {
  TrainHeroicClient,
  queryAnalytics,
  fetchStreams,
  sendComment,
} from "${NPM_JS}";

const client = new TrainHeroicClient(email, password);

await queryAnalytics(client, {
  metric: "readiness-team",
  teamId: 42,
  date: "2026-06-22",
});

const team = (await fetchStreams(client)).find((s) => s.kind === "team");
if (team && typeof team.stream.id === "number") {
  await sendComment(client, team.stream.id, "Great week.");
}`}
        />
      </section>

      <section class="doc narrow">
        <p class="faint">
          The client logs in on first use and renews the session when it expires. On Node, import
          <code>{NPM_JS}/node</code> to cache the exercise library between runs (see the coach
          example above).
          <a href="https://www.npmjs.com/package/@trainheroic-unofficial/js">Full API on npm ↗</a>
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
