---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import { NPM_DTO, NPM_JS } from "../data/tools";
---

<Layout
  title="TypeScript SDK"
  description="TypeScript SDK for TrainHeroic: exercises, workouts, athlete training, analytics, messaging."
>
  <Header />
  <main id="main">
    <div class="shell narrow">
      <header class="doc__intro">
        <h1>TypeScript SDK</h1>
        <p class="lead">
          Package <code>{NPM_JS}</code> wraps auth, workouts, roster helpers, athlete reads,
          analytics, and messaging. Types ship in <code>{NPM_DTO}</code>. The runtime runs on Node,
          workerd, and browsers.
        </p>
        <p class="doc__back"><a href="/developers">← Developers</a></p>
      </header>

      <section class="doc" id="install">
        <h2>Install</h2>
        <Snippet code={`npm install ${NPM_JS}`} />
      </section>

      <section class="doc" id="coach">
        <h2>Coach workflow</h2>
        <Snippet
          lang="typescript"
          code={`import {
  TrainHeroicClient,
  ExerciseLibrary,
  buildSession,
  fetchCoachRoster,
} from "${NPM_JS}";
import { JsonFileLibraryCache } from "${NPM_JS}/node";

const client = new TrainHeroicClient(email, password);
const library = new ExerciseLibrary(client, new JsonFileLibraryCache());

for (const athlete of await fetchCoachRoster(client)) {
  console.log(athlete.name, athlete.id);
}

const { match } = await library.resolve("Back Squat");
if (!match) throw new Error("Resolve to one exercise first");

const { pwId } = await buildSession(client, {
  programId: 12345, // from list_teams → group_program
  date: [2026, 6, 22],
  blocks: [{
    title: "Strength",
    exercises: [{ id: match.id, sets: 5, reps: 5, weight: 225, rpe: 8 }],
  }],
  publish: false,
});`}
        />
      </section>

      <section class="doc" id="athlete">
        <h2>Athlete reads</h2>
        <Snippet
          lang="typescript"
          code={`import {
  TrainHeroicClient,
  resolveAthleteUserId,
  fetchAthleteProfileSummary,
  searchExerciseHistory,
  fetchExerciseHistoryDetail,
  fetchPersonalRecords,
} from "${NPM_JS}";

const client = new TrainHeroicClient(email, password);
const userId = await resolveAthleteUserId(client);

const profile = await fetchAthleteProfileSummary(client, userId);
console.log(profile.volume_sum);

const [squat] = await searchExerciseHistory(client, "back squat", 1);
if (squat) {
  const id = Number(squat.id);
  console.log(await fetchExerciseHistoryDetail(client, id, userId));
  console.log(await fetchPersonalRecords(client, id));
}`}
        />
      </section>

      <section class="doc" id="analytics">
        <h2>Analytics and messaging</h2>
        <Snippet
          lang="typescript"
          code={`import {
  TrainHeroicClient,
  queryAnalytics,
  fetchStreams,
  sendComment,
} from "${NPM_JS}";

const client = new TrainHeroicClient(email, password);

await queryAnalytics(client, {
  metric: "readiness-team",
  teamId: 42,
  date: "2026-06-22",
});

const team = (await fetchStreams(client)).find((s) => s.kind === "team");
if (team && typeof team.stream.id === "number") {
  await sendComment(client, team.stream.id, "Great week.");
}`}
        />
      </section>

      <section class="doc">
        <p class="disclaimer">
          <a
            href="https://www.npmjs.com/package/@trainheroic-unofficial/js"
            aria-label="Full API on npm (opens in new tab)"
            target="_blank"
            rel="noopener noreferrer"
            >Full API on npm<span aria-hidden="true"> ↗</span></a
          >
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
