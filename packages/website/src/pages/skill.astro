---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import {
  NPM_CLI,
  SKILL_ATHLETE,
  SKILL_COACH,
  SKILL_REPO,
} from "../data/tools";
---

<Layout
  title="Claude Code skill"
  description="Install the TrainHeroic skill for Claude Code — the recommended path for coding agents that run the trainheroic CLI."
>
  <Header />
  <main id="main">
    <div class="shell narrow">
      <header class="doc__intro">
        <h1>Claude Code skill</h1>
        <p class="lead">
          The skill teaches Claude Code to run <code>{NPM_CLI}</code> — cached sessions, JSON
          output, no MCP config.
        </p>
        <p class="doc__back"><a href="/developers">← Developers</a></p>
      </header>

      <section class="doc" id="install">
        <h2>Install</h2>
        <Snippet code={`npx skills add ${SKILL_REPO}`} />
        <p>Or install the CLI and copy skills to <code>~/.claude/skills/</code>:</p>
        <Snippet
          code={`npm install -g ${NPM_CLI}
trainheroic install-skill`}
        />
      </section>

      <section class="doc" id="credentials">
        <h2>Credentials</h2>
        <Snippet
          code={`export TRAINHEROIC_EMAIL=coach@example.com
export TRAINHEROIC_PASSWORD=yourpassword`}
        />
        <p class="disclaimer">
          Session cached at <code>~/.trainheroic/session.json</code>. Credentials live in your
          environment.
        </p>
      </section>

      <section class="doc" id="use">
        <h2>Use in Claude Code</h2>
        <ul class="doc-list">
          <li><strong>Coach</strong> — <code>/{SKILL_COACH}</code></li>
          <li><strong>Athlete</strong> — <code>/{SKILL_ATHLETE}</code></li>
        </ul>
      </section>

      <section class="doc" id="cli">
        <h2>CLI</h2>
        <Snippet
          code={`trainheroic whoami
trainheroic coach athletes
trainheroic athlete profile
trainheroic athlete export
trainheroic help`}
        />
      </section>
    </div>
  </main>
  <Footer />
</Layout>
