---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import CopyLine from "../components/CopyLine.astro";
import ToolIndex from "../components/ToolIndex.astro";
import {
  ATHLETE_TOOL_GROUPS,
  COACH_TOOL_GROUPS,
  HOSTED_ONLY_TOOLS,
} from "../data/mcp-tools";
import {
  MCP_ATHLETE_URL,
  MCP_COACH_URL,
  MCP_URL,
  NPM_ATHLETE_MCP,
  NPM_COACH_MCP,
} from "../data/tools";
---

<Layout
  title="MCP"
  description="Connect Claude and other AI assistants to TrainHeroic with a hosted MCP server or local stdio servers."
>
  <Header />
  <main id="main">
    <div class="shell">
      <header class="doc__intro narrow">
        <h1>MCP</h1>
        <p class="lead">
          Callable tools for coaches and athletes over the
          <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener noreferrer"
            >Model Context Protocol</a
          >. Sign in with your TrainHeroic account — no separate API key.
        </p>
      </header>

      <section class="doc narrow">
        <h2 id="choose">Which setup?</h2>
        <ul class="list-plain">
          <li>
            <strong>Hosted</strong> — you use Claude.ai, Cursor, or Claude Desktop and want OAuth.
            Start with the HTTP URL below.
          </li>
          <li>
            <strong>Local coach</strong> — you run Claude Code on your machine with a coach account.
            Use the stdio command or config block.
          </li>
          <li>
            <strong>Local athlete</strong> — athlete-only account, or you want a separate stdio
            process. See <a href="#local-athlete">local athlete server</a>.
          </li>
        </ul>
      </section>

      <section class="doc" id="setup">
        <h2 class="narrow">Hosted — recommended</h2>
        <p class="narrow">
          One URL for coach and athlete tools. A coach account gets both surfaces; an athlete
          account gets athlete tools only.
        </p>
        <CopyLine text={MCP_URL} label="Main endpoint" />
        <Snippet
          label="Claude Code"
          code={`claude mcp add trainheroic --transport http \\
  ${MCP_URL}`}
        />
        <Snippet
          label="Cursor or Claude Desktop (~/.cursor/mcp.json or claude_desktop_config.json)"
          code={`{
  "mcpServers": {
    "trainheroic": {
      "url": "${MCP_URL}"
    }
  }
}`}
        />
        <p class="narrow">
          <strong>Claude.ai:</strong> Settings → Connectors → add custom connector → paste the URL
          above.
        </p>
        <p class="narrow">
          <strong>Scoped endpoints:</strong>
        </p>
        <CopyLine text={MCP_COACH_URL} label="Coach only" />
        <CopyLine text={MCP_ATHLETE_URL} label="Athlete only" />
      </section>

      <section class="doc narrow">
        <h2 id="local-coach">Local coach server</h2>
        <p>Stdio on your machine. Credentials live in your MCP client config.</p>
        <Snippet
          label="Claude Code"
          code={`claude mcp add trainheroic \\
  -e TRAINHEROIC_EMAIL=coach@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_COACH_MCP}`}
        />
        <Snippet
          label="Cursor or Claude Desktop"
          code={`{
  "mcpServers": {
    "trainheroic": {
      "command": "npx",
      "args": ["-y", "${NPM_COACH_MCP}"],
      "env": {
        "TRAINHEROIC_EMAIL": "coach@example.com",
        "TRAINHEROIC_PASSWORD": "yourpassword"
      }
    }
  }
}`}
        />
        <Snippet label="Run once without installing" code={`npx -y ${NPM_COACH_MCP}`} />
        <p class="disclaimer">
          <strong>Local configs store credentials in plaintext.</strong> Use hosted OAuth if you
          can. Only run local stdio on a machine you control.
        </p>
      </section>

      <section class="doc narrow">
        <h2>Features</h2>
        <ul class="list-plain">
          <li><strong>Coach</strong> — workouts, roster, teams, analytics, messaging</li>
          <li><strong>Athlete</strong> — history, PRs, working maxes, logging</li>
          <li><strong>Confirm gates</strong> — destructive writes ask before they run</li>
        </ul>
        <p>
          Works with Claude.ai, Claude Code, Claude Desktop, Cursor, and any MCP client with HTTP
          or stdio.
        </p>
      </section>

      <section class="doc narrow">
        <h2>Example prompts</h2>
        <p>After connecting, ask in plain language — you do not need tool names:</p>
        <Snippet
          label="Things to try"
          code={`List my athletes
What's on the program for Tuesday?
Show Jordan's squat PRs this year
Draft a 5x5 back squat for June 22 — don't publish yet`}
        />
      </section>

      <section class="doc narrow" id="local-athlete">
        <h2>Local athlete server</h2>
        <Snippet
          label="Claude Code"
          code={`claude mcp add trainheroic-athlete \\
  -e TRAINHEROIC_EMAIL=athlete@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_ATHLETE_MCP}`}
        />
        <Snippet
          label="Cursor or Claude Desktop"
          code={`{
  "mcpServers": {
    "trainheroic-athlete": {
      "command": "npx",
      "args": ["-y", "${NPM_ATHLETE_MCP}"],
      "env": {
        "TRAINHEROIC_EMAIL": "athlete@example.com",
        "TRAINHEROIC_PASSWORD": "yourpassword"
      }
    }
  }
}`}
        />
      </section>

      <section class="doc narrow" id="tools">
        <h2>Tools</h2>
        <p>
          Tool names are for reference — assistants pick the right call from your question. A coach
          account on the main endpoint gets coach tools plus your own athlete tools.
        </p>
        <ToolIndex
          coachGroups={COACH_TOOL_GROUPS}
          athleteGroups={ATHLETE_TOOL_GROUPS}
          hostedOnly={HOSTED_ONLY_TOOLS}
        />
      </section>
    </div>
  </main>
  <Footer />
</Layout>
