---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import {
  MCP_ATHLETE_URL,
  MCP_COACH_URL,
  MCP_URL,
  NPM_ATHLETE_MCP,
  NPM_COACH_MCP,
} from "../data/tools";
---

<Layout
  title="MCP"
  description="Connect Claude and other AI assistants to TrainHeroic with a hosted MCP server or local stdio servers."
>
  <Header />
  <main>
    <div class="shell">
      <header class="doc__intro narrow">
        <h1>MCP</h1>
        <p class="lead">
          Callable tools for coaches and athletes over the
          <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener noreferrer"
            >Model Context Protocol</a
          >. Sign in with your TrainHeroic account — no separate API key.
        </p>
      </header>

      <section class="doc">
        <Snippet
          code={`# Hosted — recommended
claude mcp add trainheroic --transport http \\
  ${MCP_URL}

# Local coach
claude mcp add trainheroic \\
  -e TRAINHEROIC_EMAIL=coach@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_COACH_MCP}

# Or run once without installing
npx -y ${NPM_COACH_MCP}`}
        />
        <span class="url-line">{MCP_URL}</span>
      </section>

      <section class="doc narrow">
        <h2>Features</h2>
        <ul class="list-plain">
          <li><strong>Coach</strong> — workouts, roster, teams, analytics, messaging</li>
          <li><strong>Athlete</strong> — history, PRs, working maxes, logging</li>
          <li><strong>Hosted</strong> — OAuth; credentials stay on the server</li>
          <li><strong>Local</strong> — stdio on your machine, one account per process</li>
          <li><strong>Confirm gates</strong> — destructive writes ask before they run</li>
        </ul>
      </section>

      <section class="doc narrow">
        <h2>Works with</h2>
        <p>
          Claude.ai, Claude Code, Claude Desktop, Cursor, and any MCP client with HTTP or stdio.
        </p>
        <p>
          <strong>Claude.ai:</strong> Settings → Connectors → paste <code>{MCP_URL}</code>
        </p>
        <p>
          <strong>Scoped URLs:</strong> <code>{MCP_COACH_URL}</code> (coach only) ·
          <code>{MCP_ATHLETE_URL}</code> (athlete only)
        </p>
      </section>

      <section class="doc narrow">
        <h2>Example</h2>
        <p>After connecting, ask in plain language:</p>
        <Snippet
          code={`"List my athletes"
"What's on the program for Tuesday?"
"Show Jordan's squat PRs this year"
"Draft a 5x5 back squat for June 22 — don't publish yet"`}
        />
      </section>

      <section class="doc narrow">
        <h2>Local athlete server</h2>
        <Snippet
          code={`claude mcp add trainheroic-athlete \\
  -e TRAINHEROIC_EMAIL=athlete@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_ATHLETE_MCP}`}
        />
        <p class="faint" style="margin-top: 1rem;">
          Local configs store <code>TRAINHEROIC_EMAIL</code> and <code>TRAINHEROIC_PASSWORD</code>
          in plaintext.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
