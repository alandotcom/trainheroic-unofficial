---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Snippet from "../components/Snippet.astro";
import ToolIndex from "../components/ToolIndex.astro";
import {
  ATHLETE_TOOL_GROUPS,
  COACH_TOOL_GROUPS,
  HOSTED_ONLY_TOOLS,
} from "../data/mcp-tools";
import {
  MCP_ATHLETE_URL,
  MCP_COACH_URL,
  MCP_URL,
  NPM_ATHLETE_MCP,
  NPM_COACH_MCP,
} from "../data/tools";
---

<Layout
  title="MCP reference"
  description="MCP setup for Cursor and Claude Desktop, local stdio servers, and the full tool list."
>
  <Header />
  <main id="main">
    <div class="shell narrow">
      <header class="doc__intro">
        <h1>MCP reference</h1>
        <p class="lead">
          For Claude.ai, use the <a href="/">connector setup</a>. This page is for other MCP
          clients and local servers.
        </p>
        <p class="doc__back"><a href="/developers">← Developers</a></p>
      </header>

      <section class="doc" id="hosted">
        <h2>Hosted endpoint</h2>
        <Snippet code={MCP_URL} lang="text" />
        <Snippet
          lang="json"
          code={`{
  "mcpServers": {
    "trainheroic": {
      "url": "${MCP_URL}"
    }
  }
}`}
        />
        <p>Scoped endpoints:</p>
        <Snippet code={MCP_COACH_URL} lang="text" />
        <Snippet code={MCP_ATHLETE_URL} lang="text" />
      </section>

      <section class="doc" id="local-coach">
        <h2>Local coach server</h2>
        <Snippet
          code={`claude mcp add trainheroic \\
  -e TRAINHEROIC_EMAIL=coach@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_COACH_MCP}`}
        />
        <Snippet
          lang="json"
          code={`{
  "mcpServers": {
    "trainheroic": {
      "command": "npx",
      "args": ["-y", "${NPM_COACH_MCP}"],
      "env": {
        "TRAINHEROIC_EMAIL": "coach@example.com",
        "TRAINHEROIC_PASSWORD": "yourpassword"
      }
    }
  }
}`}
        />
      </section>

      <section class="doc" id="local-athlete">
        <h2>Local athlete server</h2>
        <Snippet
          code={`claude mcp add trainheroic-athlete \\
  -e TRAINHEROIC_EMAIL=athlete@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_ATHLETE_MCP}`}
        />
      </section>

      <section class="doc" id="tools">
        <h2>Tool list</h2>
        <ToolIndex
          coachGroups={COACH_TOOL_GROUPS}
          athleteGroups={ATHLETE_TOOL_GROUPS}
          hostedOnly={HOSTED_ONLY_TOOLS}
        />
      </section>
    </div>
  </main>
  <Footer />
</Layout>
