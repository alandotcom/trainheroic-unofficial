---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CodeBlock from "../components/CodeBlock.astro";
import {
  MCP_ATHLETE_URL,
  MCP_COACH_URL,
  MCP_URL,
  NPM_ATHLETE_MCP,
  NPM_COACH_MCP,
} from "../data/tools";
---

<Layout
  title="MCP"
  description="Connect Claude and other AI assistants to TrainHeroic with a hosted MCP server or local stdio servers."
>
  <Header />
  <main>
    <header class="page-header container">
      <h1>TrainHeroic MCP</h1>
      <p>
        Browser automation-style tools for strength coaches and athletes. Give your assistant
        access to programming, roster management, training history, and messaging through the
        <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener noreferrer"
          >Model Context Protocol</a
        >.
      </p>
    </header>

    <section class="container" style="padding-bottom: 2rem;">
      <CodeBlock
        code={`# Hosted (recommended) — OAuth login
claude mcp add trainheroic --transport http \\
  ${MCP_URL}

# Local coach — credentials from your environment
claude mcp add trainheroic \\
  -e TRAINHEROIC_EMAIL=coach@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_COACH_MCP}

# Or try without installing a local server
npx -y ${NPM_COACH_MCP}   # needs TRAINHEROIC_EMAIL + TRAINHEROIC_PASSWORD`}
      />
      <div class="endpoint" style="margin-top: 1.25rem;">
        <span class="endpoint__dot" aria-hidden="true"></span>
        {MCP_URL}
      </div>
    </section>

    <section class="section container section--ruled">
      <h2>Features</h2>
      <ul class="feature-bullets">
        <li>
          <strong>Coach tools</strong> — build and publish workouts, manage athletes and teams,
          read analytics, send messages
        </li>
        <li>
          <strong>Athlete tools</strong> — training history, PRs, working maxes, log sets and
          sessions
        </li>
        <li>
          <strong>Hosted</strong> — sign in with OAuth; credentials stay on the server
        </li>
        <li>
          <strong>Local</strong> — stdio servers for a single account on your machine
        </li>
        <li>
          <strong>Role-aware</strong> — coach accounts get coaching plus their own athlete data;
          athlete accounts get the athlete surface
        </li>
        <li>
          <strong>Confirm gates</strong> — destructive writes ask before they run
        </li>
      </ul>
    </section>

    <section class="section container section--ruled">
      <h2>Works with</h2>
      <p class="section__lead">
        Claude.ai, Claude Code, Claude Desktop, Cursor, and any MCP client that supports HTTP or
        stdio transports.
      </p>
      <dl class="cap-list">
        <div>
          <dt>Claude.ai</dt>
          <dd>
            Settings → Connectors → Add custom connector. Paste <code>{MCP_URL}</code> and sign in
            with your TrainHeroic account.
          </dd>
        </div>
        <div>
          <dt>Claude Desktop</dt>
          <dd>
            Add an <code>mcpServers</code> entry pointing at <code>npx -y {NPM_COACH_MCP}</code> (or
            the athlete package) with your credentials in <code>env</code>.
          </dd>
        </div>
        <div>
          <dt>Scoped endpoints</dt>
          <dd>
            <code>{MCP_COACH_URL}</code> for coaching only · <code>{MCP_ATHLETE_URL}</code> for
            athlete training only
          </dd>
        </div>
      </dl>
    </section>

    <section class="section container section--ruled">
      <h2>Example</h2>
      <p class="section__lead">After connecting, ask your assistant in plain language:</p>
      <CodeBlock
        code={`"List my athletes"
"What's programmed for Tuesday?"
"Show squat PRs for Jordan this year"
"Build a 5x5 back squat session for June 22 and leave it as a draft"
"Send the team a reminder about tomorrow's session"`}
      />
      <p class="prose" style="margin-top: 1.25rem; max-width: 38rem;">
        The assistant picks the right tool — <code>list_athletes</code>,
        <code>athlete_training</code>, <code>workout_build</code>, <code>message_send</code>, and
        dozens more — from the connection you configured.
      </p>
    </section>

    <section class="section container section--ruled">
      <h2>Local servers</h2>
      <p class="section__lead">
        Two packages, one account each. Credentials are read from the environment and stored in
        plaintext in your MCP config.
      </p>
      <CodeBlock
        label="Athlete account"
        code={`claude mcp add trainheroic-athlete \\
  -e TRAINHEROIC_EMAIL=athlete@example.com \\
  -e TRAINHEROIC_PASSWORD=yourpassword \\
  -- npx -y ${NPM_ATHLETE_MCP}`}
      />
      <div class="callout">
        <p>
          <strong>Credentials:</strong> hosted OAuth keeps passwords off your machine. Local stdio
          servers need <code>TRAINHEROIC_EMAIL</code> and <code>TRAINHEROIC_PASSWORD</code> in the
          environment or MCP config.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
