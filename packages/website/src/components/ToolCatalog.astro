---
import type { ToolGroup } from "../data/tools";

interface Props {
  groups: ToolGroup[];
}

const { groups } = Astro.props;
---

<div class="tool-grid">
  {
    groups.map((group) => (
      <section class="tool-group">
        <div class="tool-group__header">
          <h3 class="tool-group__title">{group.title}</h3>
          {group.hostedOnly ? (
            <span class="tool-group__badge tool-group__badge--hosted">Hosted only</span>
          ) : null}
        </div>
        <ul class="tool-list">
          {group.tools.map((tool) => (
            <li>{tool}</li>
          ))}
        </ul>
      </section>
    ))
  }
</div>
