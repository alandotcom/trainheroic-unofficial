---
const path = Astro.url.pathname;

const links = [
  { href: "/mcp", label: "MCP" },
  { href: "/sdk", label: "SDK" },
  { href: "https://github.com/alandotcom/trainheroic-unofficial", label: "GitHub", external: true },
];
---

<header class="site-header shell">
  <div class="site-header__inner">
    <a class="brand" href="/">trainheroic <span>unofficial</span></a>
    <nav class="nav" aria-label="Main">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={path === link.href ? "page" : undefined}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
          >
            {link.label}
            {link.external ? " ↗" : ""}
          </a>
        ))
      }
    </nav>
  </div>
</header>
