---
interface Props {
  text: string;
  label?: string;
}

const { text, label = "Endpoint URL" } = Astro.props;
---

<div class="copy-line" data-copy-source>
  <span class="copy-line__label">{label}</span>
  <code class="copy-line__text" data-copy-text>{text}</code>
  <button type="button" class="copy-btn copy-btn--inline" data-copy aria-label={`Copy ${label}`}>
    <span class="copy-btn__idle" aria-hidden="true">Copy</span>
    <span class="copy-btn__done" aria-hidden="true">Copied</span>
  </button>
</div>

<script>
  import "../scripts/copy.ts";
</script>
