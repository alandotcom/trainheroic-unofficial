  },
  "dependencies": {
    "@trainheroic-unofficial/dto": "workspace:*",
    "@trainheroic-unofficial/js": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
