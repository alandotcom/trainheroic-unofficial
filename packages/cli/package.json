{
  "name": "@trainheroic-unofficial/cli",
  "version": "1.5.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alandotcom/trainheroic-unofficial.git",
    "directory": "packages/cli"
  },
  "description": "Command-line tool for the TrainHeroic API.",
  "type": "module",
  "bin": {
    "trainheroic": "./dist/cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "start": "tsx src/cli.ts",
