{
  "name": "@trainheroic-unofficial/dto",
  "version": "1.1.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alandotcom/trainheroic-unofficial.git",
    "directory": "packages/dto"
  },
  "description": "Domain DTOs and zod schemas for TrainHeroic — the single source of truth for shapes.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
