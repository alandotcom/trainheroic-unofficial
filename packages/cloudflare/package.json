{
  "name": "@trainheroic-unofficial/cloudflare",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "inspect": "npx @modelcontextprotocol/inspector",
    "deploy": "sh scripts/deploy.sh",
    "deploy:plain": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "wrangler d1 migrations apply trainheroic --remote",
    "db:migrate:local": "wrangler d1 migrations apply trainheroic --local"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/cloudflare": "^10.59.0",
    "@trainheroic-unofficial/core": "workspace:*",
    "@trainheroic-unofficial/db": "workspace:*",
    "@trainheroic-unofficial/js": "workspace:*",
    "agents": "^0.16.2",
    "drizzle-orm": "1.0.0-rc.3",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@types/node": "^26.0.0",
    "drizzle-kit": "1.0.0-rc.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
