{
  "name": "@trainheroic-unofficial/js",
  "version": "1.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alandotcom/trainheroic-unofficial.git",
    "directory": "packages/js"
  },
  "description": "Unofficial TypeScript SDK for the TrainHeroic coaching API.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./src/node.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./node": {
        "types": "./dist/node.d.mts",
        "import": "./dist/node.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@trainheroic-unofficial/dto": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
