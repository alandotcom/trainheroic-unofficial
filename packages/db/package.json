{
  "name": "@trainheroic-unofficial/db",
  "version": "1.3.0",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/alandotcom/trainheroic-unofficial.git",
    "directory": "packages/db"
  },
  "description": "Shared Drizzle warehouse: one schema + store layer, with D1 (Cloudflare) and node:sqlite (local) adapters.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./d1": {
      "types": "./src/d1.ts",
      "import": "./src/d1.ts"
    },
    "./sqlite": {
      "types": "./src/sqlite.ts",
      "import": "./src/sqlite.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@trainheroic-unofficial/dto": "workspace:*",
    "@trainheroic-unofficial/js": "workspace:*",
    "drizzle-orm": "1.0.0-rc.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
