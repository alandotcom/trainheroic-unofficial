{
  "name": "@trainheroic-unofficial/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "oxlint --deny-warnings",
    "fmt": "oxfmt packages",
    "fmt:check": "oxfmt --check packages",
    "check:versions": "node scripts/check-versions.mjs",
    "check": "pnpm run check:versions && pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "deploy": "pnpm --filter @trainheroic-unofficial/cloudflare run deploy",
    "eval": "RUN_EVALS=1 pnpm --filter @trainheroic-unofficial/eval run eval",
    "eval:mcp": "RUN_EVALS=1 EVAL_SURFACES=mcp pnpm --filter @trainheroic-unofficial/eval run eval",
    "eval:cli": "RUN_EVALS=1 EVAL_SURFACES=cli pnpm --filter @trainheroic-unofficial/eval run eval",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3"
  }
}
